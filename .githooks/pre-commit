#!/usr/bin/env bash
# Second Brain pre-commit hook.
#  1. If glossary_autolink is enabled, link known glossary terms in staged notes and
#     re-stage them (scripts/glossary_autolink_staged.py) — BEFORE embedding, so a note
#     embeds with its links. No-op when the toggle is off (the default).
#  2. Regenerate `.embed.json` sidecars for staged PARA notes and stage them into
#     the same commit (scripts/embed_staged.py).
#  3. Warn — never block — when a staged Markdown note exceeds 300 non-empty lines
#     (scripts/check_line_count.py, Task 0002). Excludes README.md and tasks/.
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"

python3 "$ROOT/scripts/glossary_autolink_staged.py"
python3 "$ROOT/scripts/embed_staged.py"

staged_md="$(git diff --cached --name-only --diff-filter=ACM -- '*.md')"
if [ -n "$staged_md" ]; then
  # shellcheck disable=SC2086  # intentional word-split; note paths have no spaces
  python3 "$ROOT/scripts/check_line_count.py" $staged_md || true
fi
